	<Button name="CraftButtonTemplate" inherits="ClassTrainerSkillButtonTemplate" hidden="false" virtual="true">
		<Layers>
			<Layer level="BACKGROUND">
				<FontString name="$parentCost" inherits="GameFontNormal">
					<Anchors>
						<Anchor point="RIGHT">
							<Offset>
								<AbsDimension x="-15" y="0"/>
							</Offset>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Scripts>
			<OnClick>
				CraftButton_OnClick(arg1);
			</OnClick>
			<OnLeave>
				if ( GetCraftSelectionIndex() ~= this:GetID() ) then
					_G[this:GetName().."SubText"]:SetTextColor(this.r, this.g, this.b);
				end
			</OnLeave>
		</Scripts>
	</Button>
	<Button name="CraftItemTemplate" inherits="QuestItemTemplate" virtual="true">
		<Scripts>
			<OnEnter>
				GameTooltip:SetOwner(this, "ANCHOR_TOPLEFT");
				GameTooltip:SetCraftItem(GetCraftSelectionIndex(), this:GetID());
				CursorUpdate();
			</OnEnter>
			<OnLeave>
				GameTooltip:Hide();
				ResetCursor();
			</OnLeave>
			<OnUpdate>
				CursorOnUpdate();
			</OnUpdate>
			<OnClick>
				if ( IsControlKeyDown() ) then
					DressUpItemLink(GetCraftReagentItemLink(GetCraftSelectionIndex(), this:GetID()));
				elseif ( IsShiftKeyDown() ) then
					if ( ChatFrameEditBox:IsVisible() ) then
						ChatFrameEditBox:Insert(GetCraftReagentItemLink(GetCraftSelectionIndex(), this:GetID()));
					end
				end
			</OnClick>
		</Scripts>
	</Button>
