<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\FrameXML\UI.xsd">
	<Script file="CustomMerchantFrame.lua"/>
	<Frame name="CustomMerchantItemTemplate" virtual="true">
		<Size x="153" y="44"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentSlotTexture" file="Interface\Buttons\UI-EmptySlot">
					<Size x="64" y="64"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="-13" y="13"/>
						</Anchor>
					</Anchors>
				</Texture>
				<Texture name="$parentNameFrame" file="Interface\MerchantFrame\UI-Merchant-LabelSlots">
					<Size x="128" y="78"/>
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parentSlotTexture" relativePoint="RIGHT">
							<Offset x="-9" y="-18"/>
						</Anchor>
					</Anchors>
				</Texture>
				<FontString name="$parentName" inherits="GameFontNormalSmall" text="Item Name" justifyH="LEFT">
					<Size x="100" y="30"/>
					<Anchors>
						<Anchor point="LEFT" relativeTo="$parentSlotTexture" relativePoint="RIGHT">
							<Offset x="-5" y="7"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentItemButton" inherits="ItemButtonTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="$parent"/>
				</Anchors>
				<Scripts>
					<OnClick>
						CustomMerchantItemButton_OnClick(arg1)
					</OnClick>
					<OnLoad>
						this:RegisterForClicks("LeftButtonUp","RightButtonUp")
						this:RegisterForDrag("LeftButton")
					</OnLoad>
					<OnDragStart>
						CustomMerchantItemButton_OnClick("LeftButton", 1)
					</OnDragStart>
					<OnEnter>
						CustomMerchantItem_OnEnter()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
						ResetCursor()
						CustomMerchantFrame.itemHover = nil
					</OnLeave>
					<OnHide>
						if this.hasStackSplit == 1 then
							StackSplitFrame:Hide()
						end
					</OnHide>
				</Scripts>
			</Button>
			<Frame name="$parentAltCurrencyFrame" inherits="SmallAlterateCurrencyFrameTemplate" hidden="true">
				<Anchors>
					<Anchor point="BOTTOMLEFT" relativeTo="$parentNameFrame" relativePoint="BOTTOMLEFT">
						<Offset x="2" y="31"/>
					</Anchor>
				</Anchors>
			</Frame>
		</Frames>
	</Frame>
	<Frame name="CustomMerchantFrame" toplevel="true" parent="UIParent" movable="true" enableMouse="true" hidden="true">
		<Size x="384" y="470"/>
		<Anchors>
			<Anchor point="TOPLEFT">
				<Offset x="0" y="-104"/>
			</Anchor>
		</Anchors>
		<HitRectInsets left="0" right="35" top="0" bottom="25"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="CustomMerchantFramePortrait">
					<Size x="60" y="60"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="7" y="-6"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="BORDER">
				<Texture file="Interface\MerchantFrame\UI-Merchant-TopLeft">
					<Size x="256" y="256"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</Texture>
				<Texture file="Interface\MerchantFrame\UI-Merchant-TopRight">
					<Size x="128" y="256"/>
					<Anchors>
						<Anchor point="TOPRIGHT"/>
					</Anchors>
				</Texture>
				<Texture file="Interface\MerchantFrame\UI-Merchant-BotLeft">
					<Size x="256" y="256"/>
					<Anchors>
						<Anchor point="BOTTOMLEFT"/>
					</Anchors>
				</Texture>
				<Texture file="Interface\MerchantFrame\UI-Merchant-BotRight">
					<Size x="128" y="256"/>
					<Anchors>
						<Anchor point="BOTTOMRIGHT"/>
					</Anchors>
				</Texture>
				<FontString name="CustomMerchantNameText" inherits="GameFontNormal">
					<Anchors>
						<Anchor point="TOP" relativeTo="CustomMerchantFrame" relativePoint="TOP">
							<Offset x="0" y="-17"/>
						</Anchor>
					</Anchors>
				</FontString>
				<FontString name="CustomMerchantPageText" inherits="GameFontNormal">
					<Size x="104" y="0"/>
					<Anchors>
						<Anchor point="BOTTOM">
							<Offset x="-14" y="102"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Frame name="CustomMerchantItem1" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="24" y="-80"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem2" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem1" relativePoint="TOPRIGHT">
						<Offset x="12" y="0"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem3" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem1" relativePoint="BOTTOMLEFT">
						<Offset x="0" y="-8"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem4" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem3" relativePoint="TOPRIGHT">
						<Offset x="12" y="0"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem5" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem3" relativePoint="BOTTOMLEFT">
						<Offset x="0" y="-8"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem6" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem5" relativePoint="TOPRIGHT">
						<Offset x="12" y="0"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem7" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem5" relativePoint="BOTTOMLEFT">
						<Offset x="0" y="-8"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem8" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem7" relativePoint="TOPRIGHT">
						<Offset x="12" y="0"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem9" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem7" relativePoint="BOTTOMLEFT">
						<Offset x="0" y="-8"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Frame name="CustomMerchantItem10" inherits="CustomMerchantItemTemplate">
				<Anchors>
					<Anchor point="TOPLEFT" relativeTo="CustomMerchantItem9" relativePoint="TOPRIGHT">
						<Offset x="12" y="0"/>
					</Anchor>
				</Anchors>
			</Frame>
			<Button name="CustomMerchantPrevPageButton">
				<Size x="32" y="32"/>
				<Anchors>
					<Anchor point="CENTER" relativeTo="CustomMerchantFrame" relativePoint="BOTTOMLEFT">
						<Offset x="37" y="109"/>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<FontString inherits="GameFontNormal" justifyH="LEFT" text="PREV">
							<Anchors>
								<Anchor point="LEFT" relativeTo="CustomMerchantPrevPageButton" relativePoint="RIGHT"/>
							</Anchors>
						</FontString>
						<Texture file="Interface\Buttons\UI-PageButton-Background">
							<Size x="32" y="32"/>
							<Anchors>
								<Anchor point="CENTER">
									<Offset x="0" y="1"/>
								</Anchor>
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnClick>
						CustomMerchantPrevPageButton_OnClick()
					</OnClick>
				</Scripts>
				<NormalTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Up"/>
				<PushedTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" alphaMode="ADD"/>
			</Button>
			<Button name="CustomMerchantNextPageButton">
				<Size x="32" y="32"/>
				<Anchors>
					<Anchor point="CENTER" relativeTo="CustomMerchantFrame" relativePoint="BOTTOMLEFT">
						<Offset x="324" y="109"/>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="BACKGROUND">
						<FontString inherits="GameFontNormal" justifyH="RIGHT" text="NEXT">
							<Anchors>
								<Anchor point="RIGHT" relativeTo="CustomMerchantNextPageButton" relativePoint="LEFT">
									<Offset x="-3" y="0"/>
								</Anchor>
							</Anchors>
						</FontString>
						<Texture file="Interface\Buttons\UI-PageButton-Background">
							<Size x="32" y="32"/>
							<Anchors>
								<Anchor point="CENTER">
									<Offset x="0" y="1"/>
								</Anchor>
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnClick>
						CustomMerchantNextPageButton_OnClick()
					</OnClick>
				</Scripts>
				<NormalTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Up"/>
				<PushedTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" alphaMode="ADD"/>
			</Button>
			<Button name="CustomMerchantFrameHonorAmount" inherits="SmallDenominationTemplate">
				<Anchors>
					<Anchor point="BOTTOMRIGHT" relativeTo="CustomMerchantFrame" relativePoint="BOTTOMRIGHT">
						<Offset x="-55" y="68"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
						GameTooltip:SetText(HONOR)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Button>
			<Button name="CustomMerchantFrameArenaAmount" inherits="SmallDenominationTemplate">
				<Anchors>
					<Anchor point="RIGHT" relativeTo="CustomMerchantFrameHonorAmount" relativePoint="LEFT">
						<Offset x="-8" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
						GameTooltip:SetText(ARENA_CONQUEST_POINTS)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Button>
			<Button name="CustomMerchantFrameCloseButton" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" relativeTo="CustomMerchantFrame" relativePoint="TOPRIGHT">
						<Offset x="-30" y="-8"/>
					</Anchor>
				</Anchors>
			</Button>
		</Frames>
		<Scripts>
			<OnHide>
				CustomMerchantFrame_OnHide()
				PlaySound("igCharacterInfoClose")
			</OnHide>
			<OnLoad>
				CustomMerchantFrame_OnLoad()
			</OnLoad>
			<OnShow>
				CustomMerchantFrame_OnShow()
				PlaySound("igCharacterInfoOpen")
			</OnShow>
			<OnEvent>
				CustomMerchantFrame_OnEvent()
			</OnEvent>
			<OnUpdate>
				if CustomMerchantFrame.itemHover then
					if IsControlKeyDown() then
						ShowInspectCursor()
					else
						ResetCursor()
						SetCursor("BUY_CURSOR")
					end
				end
			</OnUpdate>
			<OnReceiveDrag>
				CustomMerchantItemButton_OnClick("LeftButton")
			</OnReceiveDrag>
		</Scripts>
	</Frame>
</Ui>
