<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
	<Script file="Turtle_TransmogUI.lua"/>
	<Frame name="NewTransmogAlertFrame" toplevel="true" parent="UIParent" movable="true" enableMouse="true">
		<Size x="250" y="20"/>
		<Anchors>
			<Anchor point="BOTTOM">
				<Offset x="0" y="300"/>
			</Anchor>
		</Anchors>
		<Layers>
			<Layer level="OVERLAY">
				<FontString name="$parentTitle" inherits="GameFontNormal" text="[New Transmog] ANCHOR">
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentTestPlacement" inherits="UIPanelButtonTemplate2" text="Test">
				<Size x="50" y="40"/>
				<Anchors>
					<Anchor point="LEFT"/>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_TestNewTransmogAlert()
					</OnClick>
				</Scripts>
			</Button>
			<Button name="$parentClosePlacement" inherits="UIPanelButtonTemplate2" text="CLOSE">
				<Size x="50" y="40"/>
				<Anchors>
					<Anchor point="RIGHT"/>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_ClosePlacement()
					</OnClick>
				</Scripts>
			</Button>
		</Frames>
		<Scripts>
			<OnLoad>
				this:RegisterForDrag("LeftButton")
				this:SetMovable(1)
				this:SetUserPlaced(true)
			</OnLoad>
			<OnDragStart>
				this:StartMoving()
				this.isMoving = true
			</OnDragStart>
			<OnDragStop>
				this:StopMovingOrSizing()
				this.isMoving = false
			</OnDragStop>
		</Scripts>
	</Frame>
