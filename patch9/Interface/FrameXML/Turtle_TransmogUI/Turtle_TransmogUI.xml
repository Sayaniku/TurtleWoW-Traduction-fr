		<Frames>
			<EditBox name="TransmogFrameSearch" inherits="SearchBoxTemplate" letters="120">
				<Size x="130" y="32"/>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="92" y="-40"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnTextChanged>
						Transmog_Search()
					</OnTextChanged>
				</Scripts>
			</EditBox>
			<Frame name="$parentOutfits" inherits="UIDropDownMenuTemplate">
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="5" y="-75"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_TOPRIGHT")
						GameTooltip:SetText(TRANSMOG_SELECT_OUTFIT, nil, nil, nil, nil, 1)
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Frame>
			<Button name="$parentSaveOutfit" inherits="UIPanelButtonTemplate" text="SAVE" topLevel="true">
				<Size x="60" y="24"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentOutfits" relativePoint="RIGHT">
						<Offset x="-15" y="2"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_SaveOutfit()
						PlaySound("igMainMenuOption")
					</OnClick>
				</Scripts>
			</Button>
			<Button name="$parentDeleteOutfit" hidden="true">
				<Size x="32" y="32"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentSaveOutfit" relativePoint="RIGHT">
						<Offset x="-7" y="-1"/>
					</Anchor>
				</Anchors>
				<HitRectInsets left="9" right="7" top="-7" bottom="10"/>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT", -(this:GetWidth() / 4), -(this:GetHeight() / 4))
						GameTooltip:SetText(strsub(TRANSMOG_OUTFIT_DELETE, 1, -2))
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
					<OnClick>
						StaticPopup_Show("CONFIRM_DELETE_OUTFIT")
					</OnClick>
				</Scripts>
				<NormalTexture file="Interface\Buttons\CancelButton-Up"/>
				<PushedTexture file="Interface\Buttons\CancelButton-Down"/>
				<HighlightTexture file="Interface\Buttons\CancelButton-Highlight" alphaMode="ADD"/>
			</Button>
			<Button name="$parentRevert" topLevel="true">
				<Size x="24" y="24"/>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="208" y="-120"/>
					</Anchor>
				</Anchors>
				<NormalTexture file="Interface\TransmogFrame\revert"/>
				<PushedTexture file="Interface\TransmogFrame\revert_pushed"/>
				<HighlightTexture name="$parentHighlight" file="Interface\TransmogFrame\revert_highlight" alphaMode="ADD"/>
				<Scripts>
					<OnLoad>
						this:RegisterForClicks("LeftButtonUp", "RightButtonUp")
					</OnLoad>
					<OnMouseDown>
						_G[this:GetName().."Highlight"]:Hide()
					</OnMouseDown>
					<OnMouseUp>
						_G[this:GetName().."Highlight"]:Show()
					</OnMouseUp>
					<OnClick>
						Transmog_Revert()
						PlaySound("igMainMenuOption")
					</OnClick>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
						GameTooltip:SetText(RESET, 1, 1, 1)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Button>
			<Button name="$parentItemsButton" inherits="UIPanelButtonTemplate" text="TRANSMOG_ITEMS">
