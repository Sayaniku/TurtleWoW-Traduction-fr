				</Anchors>
			</Button>
			<Button name="$parentLeftArrow" hidden="true">
				<Size x="32" y="32"/>
				<Anchors>
					<Anchor point="RIGHT" relativeTo="$parentPageText" relativePoint="RIGHT">
						<Offset x="40" y="0"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_ChangePage(-1)
						PlaySound("igMainMenuOptionCheckBoxOn")
					</OnClick>
				</Scripts>
				<NormalTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Up"/>
				<PushedTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-SpellbookIcon-PrevPage-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" alphaMode="ADD"/>
			</Button>
			<Button name="$parentRightArrow" hidden="true">
				<Size x="32" y="32"/>
				<Anchors>
					<Anchor point="LEFT" relativeTo="$parentLeftArrow" relativePoint="RIGHT"/>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_ChangePage(1)
						PlaySound("igMainMenuOptionCheckBoxOn")
					</OnClick>
				</Scripts>
				<NormalTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Up"/>
				<PushedTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Down"/>
				<DisabledTexture file="Interface\Buttons\UI-SpellbookIcon-NextPage-Disabled"/>
				<HighlightTexture file="Interface\Buttons\UI-Common-MouseHilight" alphaMode="ADD"/>
			</Button>
		</Frames>
		<Scripts>
			<OnLoad>
				Transmog_OnLoad()
			</OnLoad>
			<OnShow>
				PlaySound("igCharacterInfoOpen")
				TransmogFrame_OnShow()
			</OnShow>
			<OnHide>
				Transmog_OnHide()
			</OnHide>
			<OnEvent>
				TransmogFrame_OnEvent()
			</OnEvent>
			<OnDragStart>
				this:StartMoving()
				this.isMoving = true
			</OnDragStart>
			<OnDragStop>
				this:StopMovingOrSizing()
				this.isMoving = false
			</OnDragStop>
			<OnMouseWheel>
				Transmog_ChangePage(arg1)
			</OnMouseWheel>
			<OnMouseDown>
				TransmogFrameSearch:ClearFocus()
				TransmogFrameSearch:HighlightText(0, 0)
			</OnMouseDown>
		</Scripts>
