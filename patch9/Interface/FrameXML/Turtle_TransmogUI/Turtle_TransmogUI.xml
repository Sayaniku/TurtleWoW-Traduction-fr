						<Offset x="112" y="11"/>
					</Anchor>
				</Anchors>
				<Scripts>
					<OnClick>
						Transmog_ApplyOnClick()
					</OnClick>
				</Scripts>
			</Button>
			<Frame name="$parentCurrencyIcon">
				<Size x="12" y="12"/>
				<Anchors>
					<Anchor point="BOTTOMLEFT">
						<Offset x="24" y="14"/>
					</Anchor>
				</Anchors>
				<Layers>
					<Layer level="OVERLAY">
						<Texture file="Interface\Icons\INV_Misc_Ribbon_01" setAllPoints="true">
							<TexCoords left="0.08" right="0.92" top="0.08" bottom="0.92"/>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
