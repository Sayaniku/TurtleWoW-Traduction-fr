						<Offset x="-29" y="-25"/>
					</Anchor>
				</Anchors>
			</Button>
			<Button name="$parentApplyButton" inherits="StaticPopupButtonTemplate" text="GENERIC_APPLY">
				<Size x="128" y="20"/>
				<Anchors>
