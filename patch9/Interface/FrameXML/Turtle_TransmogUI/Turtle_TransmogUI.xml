						GameTooltip:AddLine(TRANSMOG_FASHION_COINS_DESC, 1, 1, 1, true)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Frame>
