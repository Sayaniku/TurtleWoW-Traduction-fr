				<PushedTexture name="$parentPushedTexture" file="Interface\TransmogFrame\tab_active">
					<Size x="128" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</PushedTexture>
				<DisabledTexture name="$parentPushedTexture" file="Interface\TransmogFrame\tab_inactive">
					<Size x="128" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</DisabledTexture>
				<Scripts>
					<OnClick>
						Transmog_SwitchTab("items")
						PlaySound("igCharacterInfoTab")
					</OnClick>
				</Scripts>
			</Button>
			<Button name="$parentSetsButton" inherits="UIPanelButtonTemplate" text="TRANSMOG_OUTFITS">
				<Size x="81" y="32"/>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="332" y="-47"/>
					</Anchor>
				</Anchors>
				<NormalTexture name="$parentNormalTexture" file="Interface\TransmogFrame\tab_inactive">
					<Size x="128" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</NormalTexture>
				<PushedTexture name="$parentPushedTexture" file="Interface\TransmogFrame\tab_inactive">
					<Size x="128" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</PushedTexture>
				<DisabledTexture name="$parentPushedTexture" file="Interface\TransmogFrame\tab_inactive">
					<Size x="128" y="32"/>
					<Anchors>
						<Anchor point="TOPLEFT"/>
					</Anchors>
				</DisabledTexture>
				<Scripts>
					<OnClick>
						Transmog_SwitchTab("sets")
