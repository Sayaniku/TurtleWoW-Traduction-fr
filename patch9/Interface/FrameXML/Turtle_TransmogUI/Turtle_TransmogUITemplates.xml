<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/..\FrameXML\UI.xsd">
	<Frame name="TransmogFrameLookTemplate" virtual="true" frameStrata="MEDIUM">
		<Size x="90" y="110"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Frames>
			<Button name="$parentButton" inherits="UIPanelButtonTemplate">
				<Size x="90" y="128"/>
				<Anchors>
					<Anchor point="LEFT"/>
				</Anchors>
				<NormalTexture file="Interface\TransmogFrame\item_bg_normal">
					<Size x="128" y="128"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="-20" y="0"/>
						</Anchor>
					</Anchors>
				</NormalTexture>
				<PushedTexture file="Interface\TransmogFrame\item_bg_selected">
					<Size x="128" y="128"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="-20" y="0"/>
						</Anchor>
					</Anchors>
				</PushedTexture>
				<HighlightTexture file="Interface\TransmogFrame\item_bg_highlight" alphaMode="ADD">
					<Size x="128" y="128"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="-20" y="0"/>
						</Anchor>
					</Anchors>
				</HighlightTexture>
				<Layers>
					<Layer level="OVERLAY">
						<Texture name="$parentRevert" hidden="true" file="Interface\TransmogFrame\revert">
							<Size x="16" y="16"/>
							<Anchors>
								<Anchor point="TOPLEFT">
									<Offset x="3" y="-9"/>
								</Anchor>
							</Anchors>
						</Texture>
						<Texture name="$parentCheck" hidden="true" file="Interface\TransmogFrame\check">
							<Size x="16" y="16"/>
							<Anchors>
								<Anchor point="TOPRIGHT">
									<Offset x="-8" y="-9"/>
								</Anchor>
							</Anchors>
						</Texture>
					</Layer>
				</Layers>
				<Scripts>
					<OnClick>
						Transmog_Try(this:GetID(), this:GetName())
					</OnClick>
					<OnEnter>
						if not this.tooltipText then
							return
						end
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT", -8, -8)
						GameTooltip:SetText(this.tooltipText)
						GameTooltip:AddLine(this.tooltipSubText)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Button>
			<DressUpModel name="$parentItemModel" scale="4.0">
				<Size x="80" y="107"/>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="4" y="0"/>
					</Anchor>
				</Anchors>
			</DressUpModel>
		</Frames>
	</Frame>
	<Frame name="TransmogWonItemTemplate" virtual="true">
		<Size x="512" y="128"/>
		<Anchors>
			<Anchor point="CENTER">
				<Offset x="0" y="-200"/>
			</Anchor>
		</Anchors>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentBackdrop"/>
			</Layer>
			<Layer level="OVERLAY">
				<FontString name="$parentItemName" inherits="GameFontNormalLarge" justifyH="LEFT">
					<Size x="160" y="35"/>
					<Anchors>
						<Anchor point="TOPLEFT">
							<Offset x="208" y="-55"/>
						</Anchor>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
		<Frames>
			<Button name="$parentIcon">
				<Size x="36" y="36"/>
				<Anchors>
					<Anchor point="LEFT">
						<Offset x="160" y="-9"/>
					</Anchor>
				</Anchors>
				<NormalTexture name="$parentNormalTexture">
					<Size x="36" y="36"/>
					<Anchors>
						<Anchor point="CENTER"/>
					</Anchors>
				</NormalTexture>
				<Scripts>
					<OnEnter>
						GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
						GameTooltip:SetHyperlink(this:GetParent().itemLink)
						GameTooltip:Show()
					</OnEnter>
					<OnLeave>
						GameTooltip:Hide()
					</OnLeave>
				</Scripts>
			</Button>
		</Frames>
	</Frame>
	<Button name="TransmogPlayerSlotTemplate" virtual="true" topLevel="true">
		<Size x="32" y="32"/>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentItemIcon">
					<Size x="26" y="26"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="3"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="BORDER">
				<Texture name="$parentBorder" file="Interface\TransmogFrame\transmog_border">
					<Size x="48" y="48"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-2" y="3"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="ARTWORK">
				<Texture name="$parentNoEquip" hidden="true" file="Interface\TransmogFrame\no_equip">
					<Size x="26" y="26"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="2"/>
						</Anchor>
					</Anchors>
				</Texture>
				<Texture name="$parentBorderHi" hidden="true" file="Interface\TransmogFrame\border_1">
					<Size x="48" y="48"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="2"/>
						</Anchor>
					</Anchors>
				</Texture>
				<Texture name="$parentBorderFull" hidden="true" file="Interface\TransmogFrame\border_full">
					<Size x="48" y="48"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="2"/>
						</Anchor>
					</Anchors>
				</Texture>
				<Texture name="$parentBorderSelected" hidden="true" file="Interface\TransmogFrame\border_2">
					<Size x="48" y="48"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="2"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="OVERLAY">
				<Texture name="$parentRevert" hidden="true" file="Interface\TransmogFrame\revert">
					<Size x="16" y="16"/>
					<Anchors>
						<Anchor point="TOPRIGHT">
							<Offset x="5" y="10"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
			<Layer level="HIGHLIGHT">
				<Texture name="$parentBorderHighlight" file="Interface\TransmogFrame\border_3">
					<Size x="48" y="48"/>
					<Anchors>
						<Anchor point="CENTER">
							<Offset x="-3" y="2"/>
						</Anchor>
					</Anchors>
				</Texture>
			</Layer>
		</Layers>
		<Frames>
			<Model name="$parentAutoCast" scale="1.3" hidden="true">
				<Size x="31" y="30"/>
				<Anchors>
					<Anchor point="TOPLEFT">
						<Offset x="-2" y="1"/>
					</Anchor>
				</Anchors>
			</Model>
		</Frames>
		<Scripts>
			<OnMouseDown>
				if (arg1 == "RightButton") then
					Transmog_Try(0, this:GetName(), true)
				else
					Transmog_SelectSlot(this:GetID(), this:GetName())
				end
			</OnMouseDown>
			<OnEnter>
				if not this.tooltipText then
					return
				end
				GameTooltip:SetOwner(this, "ANCHOR_RIGHT")
				GameTooltip:SetText(this.tooltipText)
				GameTooltip:AddLine(this.tooltipSubText)
				GameTooltip:Show()
			</OnEnter>
			<OnLeave>
				GameTooltip:Hide()
			</OnLeave>
		</Scripts>
	</Button>
</Ui>